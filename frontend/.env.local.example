# Backend API URL (Required)
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:5000

# For testing on phone (use your computer's IP address):
# Run 'ipconfig' in terminal to find your IPv4 address
# Example: NEXT_PUBLIC_API_URL=http://192.168.1.100:5000

# For production (Vercel):
# Set NEXT_PUBLIC_API_URL=https://purrfectcare.onrender.com in Vercel environment variables
